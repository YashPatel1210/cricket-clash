{
  "name": "@cricket-clash/simulation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@cricket-clash/shared": "workspace:*",
    "@cricket-clash/data": "workspace:*"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "benchmark": "tsx scripts/runBenchmark.ts",
    "simulate": "tsx scripts/simulateInnings.ts",
    "simulate:draft": "tsx scripts/simulateDraft.ts",
    "draft": "tsx scripts/interactiveDraft.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "5.9.2",
    "vitest": "^4.1.10"
  }
}
